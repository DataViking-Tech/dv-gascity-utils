#!/usr/bin/env bash
# gc-fix-refinery-routing — DEPRECATED. Forwards to gc-fix-alias-mismatch.
#
# The original helper only fixed three (later four) files in the gastown
# pack and missed every other template that emits short-form aliases —
# witness/refinery patrol formulas, mayor/deacon/crew prompts,
# mol-idea-to-plan, and so on. gc-fix-alias-mismatch is the generalized
# replacement: same idempotency guarantees, full coverage of every
# templated alias surface across every installed system pack.
#
# Tracking history:
#   - dgu-fze: original 3-file helper for the polecat -> refinery handoff.
#   - dgu-wrdjs: extended to a 4th file for the refinery -> polecat
#     rejection bounce. (Same alias-mismatch class.)
#   - dgu-yykmt: replaced this helper with the generalized audit + fixer
#     and turned this script into a shim.
#
# This shim preserves the old name so already-symlinked invocations keep
# working. Any positional args are forwarded as-is. New scripts and docs
# should call gc-fix-alias-mismatch directly.

set -euo pipefail

echo "gc-fix-refinery-routing: deprecated — forwarding to gc-fix-alias-mismatch" >&2

here="$(cd "$(dirname "$0")" && pwd)"
target="$here/gc-fix-alias-mismatch"

if [ ! -x "$target" ]; then
    echo "gc-fix-refinery-routing: gc-fix-alias-mismatch not found at $target" >&2
    exit 2
fi

exec "$target" "$@"
