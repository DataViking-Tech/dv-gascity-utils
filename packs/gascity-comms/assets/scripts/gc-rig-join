#!/usr/bin/env bash
# gc-rig-join — join an existing shared-prefix rig from a second city.
#
# Wraps the three-step recipe documented in dv-gascity-utils/docs/shared-rig-prefix.md:
#   1. pre-stage .beads/{config.yaml, metadata.json} stub
#   2. gc dolt-state ensure-project-id   (pulls canonical project_id from the DB)
#   3. gc rig add <path> --adopt --prefix <p> [--name …]
# Optionally also runs step 4: gc rig set-endpoint <name> --external …
#
# Use this on the *second* (or third, or Nth) city — the city that did NOT
# originally run `gc rig add` to create the database. The first city's flow
# is unchanged.
#
# Pre-flight checks (run before any state is written):
#   - --prefix must not collide with another rig already registered in this city
#   - target dolt server must be reachable
#   - --database (== --prefix) must already exist on that server (city A's job)
#   - that database must be bd-shaped (has metadata, issues, schema_migrations)
#
# Idempotent: safe to re-run. Each step checks whether the work is already done.

set -euo pipefail

# Source ~/.gc/secrets.env if present so GC_DOLT_USER / GC_DOLT_PASSWORD become
# the defaults for the preflight dolt calls. Matches `gc`'s own discovery path
# (every `gc dolt sql` call already honors these vars). Without this, the raw
# `dolt` invocations below cannot reach an authenticated shared server.
GC_HOME="${GC_HOME:-$HOME/.gc}"
if [ -f "$GC_HOME/secrets.env" ]; then
    set -a
    # shellcheck source=/dev/null
    . "$GC_HOME/secrets.env"
    set +a
fi

usage() {
    cat <<'EOF'
gc-rig-join — join an existing shared-prefix rig from a second city.

Usage:
  gc-rig-join <local-path> --prefix <p> [options]

Required:
  --prefix <p>           Existing rig prefix on the shared dolt (e.g. sp)

Options:
  --name <name>          Rig name in the second city's site.toml (default: derived from path)
  --host <host>          Shared dolt host (default: 127.0.0.1)
  --port <port>          Shared dolt port (default: 16022)
  --user <user>          Shared dolt user (default: $GC_DOLT_USER or root)
  --password <pw>        Shared dolt password (default: $GC_DOLT_PASSWORD,
                         else $DOLT_CLI_PASSWORD, else $MYSQL_PWD, else empty)
  --password-file <path> Read password from first line of file (overrides env)
  --pin-endpoint         After --adopt, also run `gc rig set-endpoint <name> --external …`
                         (use when the city's own dolt is NOT the shared one)
  --dry-run              Show what would be done; touch nothing
  -h, --help             Show this help

The local-path is the directory holding the project's git clone on this host.
It must already exist (you cloned the repo). This script creates `.beads/` inside it.

Auth: ~/.gc/secrets.env is sourced if present (GC_DOLT_USER, GC_DOLT_PASSWORD).
The hot-path operations (`gc dolt-state ensure-project-id`, `gc rig add --adopt`)
already honor those vars via the `gc` binary; the preflight dolt calls below
now do too. Override per-invocation with --user / --password / --password-file.

Examples:
  # Second city joining `sp` (synth-panel) where the city already use-externals
  # the shared dolt server:
  gc-rig-join ~/openclaw/midgard/rigs/synthpanel \
              --prefix sp --name synth-panel \
              --host mani-mac-mini.tail032ed9.ts.net --port 16022

  # Second city's city-level dolt is local; pin only this rig to the shared one:
  gc-rig-join /opt/projects/synthpanel \
              --prefix sp --name synth-panel \
              --host shared.example.com --port 16022 --pin-endpoint

  # Dry-run to preview:
  gc-rig-join /opt/projects/synthpanel --prefix sp --dry-run
EOF
}

LOCAL=""
PREFIX=""
NAME=""
HOST="127.0.0.1"
PORT="16022"
USER_="${GC_DOLT_USER:-root}"
PASSWORD_FLAG=""
PASSWORD_FILE=""
PASSWORD_FROM_FLAG=0
PIN_ENDPOINT=0
DRY_RUN=0

die() { echo "gc-rig-join: $*" >&2; exit 1; }

run() {
    if [ "$DRY_RUN" -eq 1 ]; then
        printf 'WOULD RUN: '
        printf '%q ' "$@"
        printf '\n'
    else
        "$@"
    fi
}

write_file() {
    local path="$1" content="$2"
    if [ "$DRY_RUN" -eq 1 ]; then
        echo "WOULD WRITE: $path"
        echo "--- contents ---"
        printf '%s' "$content"
        echo "--- end ---"
    else
        printf '%s' "$content" > "$path"
        echo "WROTE: $path"
    fi
}

while [ $# -gt 0 ]; do
    case "$1" in
        -h|--help) usage; exit 0 ;;
        --prefix) PREFIX="${2:-}"; shift 2 ;;
        --name) NAME="${2:-}"; shift 2 ;;
        --host) HOST="${2:-}"; shift 2 ;;
        --port) PORT="${2:-}"; shift 2 ;;
        --user) USER_="${2:-}"; shift 2 ;;
        --password) PASSWORD_FLAG="${2:-}"; PASSWORD_FROM_FLAG=1; shift 2 ;;
        --password-file) PASSWORD_FILE="${2:-}"; shift 2 ;;
        --pin-endpoint) PIN_ENDPOINT=1; shift ;;
        --dry-run) DRY_RUN=1; shift ;;
        --) shift; break ;;
        -*) die "unknown option: $1 (try --help)" ;;
        *)
            if [ -z "$LOCAL" ]; then LOCAL="$1"
            else die "unexpected argument: $1"
            fi
            shift
            ;;
    esac
done

# Resolve the dolt password used by the preflight dolt calls below.
# Precedence: --password-file > --password > $GC_DOLT_PASSWORD >
#             $DOLT_CLI_PASSWORD > $MYSQL_PWD > empty.
# The `dolt` CLI honors DOLT_CLI_PASSWORD (we export it on each invocation),
# so this resolution feeds that env var.
if [ -n "$PASSWORD_FILE" ]; then
    [ -r "$PASSWORD_FILE" ] || die "--password-file is not readable: $PASSWORD_FILE"
    PASSWORD=$(head -n1 "$PASSWORD_FILE")
elif [ "$PASSWORD_FROM_FLAG" -eq 1 ]; then
    PASSWORD="$PASSWORD_FLAG"
elif [ -n "${GC_DOLT_PASSWORD:-}" ]; then
    PASSWORD="$GC_DOLT_PASSWORD"
elif [ -n "${DOLT_CLI_PASSWORD:-}" ]; then
    PASSWORD="$DOLT_CLI_PASSWORD"
elif [ -n "${MYSQL_PWD:-}" ]; then
    PASSWORD="$MYSQL_PWD"
else
    PASSWORD=""
fi

[ -n "$LOCAL" ]  || { usage >&2; exit 2; }
[ -n "$PREFIX" ] || die "--prefix is required"
[ -d "$LOCAL" ]  || die "local path does not exist: $LOCAL  (clone the repo first)"

# Prefixes: bd-side rule is no hyphens (conflicts with bead ID format).
case "$PREFIX" in
    *-*) die "prefix '$PREFIX' must not contain hyphens (conflicts with bead ID format)" ;;
esac

if [ -z "$NAME" ]; then
    NAME="$(basename -- "$LOCAL")"
fi

command -v gc >/dev/null || die "gc not on PATH"

# Pre-flight 1: prefix must not collide with another rig in this city.
# The cross-rig guard distinguishes rigs by prefix; two rigs in one site.toml
# with the same prefix would make routing ambiguous.
if gc rig list --json >/tmp/.gc-rig-join-rigs.$$ 2>/dev/null; then
    if command -v jq >/dev/null 2>&1; then
        EXISTING_OWNER=$(jq -r --arg p "$PREFIX" --arg n "$NAME" \
            '.rigs[] | select(.prefix == $p and .name != $n) | .name' \
            /tmp/.gc-rig-join-rigs.$$ | head -1)
    else
        EXISTING_OWNER=$(awk -v p="\"$PREFIX\"" -v n="\"$NAME\"" '
            /"name":/  { gsub(",",""); name=$2 }
            /"prefix":/{ gsub(",",""); if ($2 == p && name != n) print name }
        ' /tmp/.gc-rig-join-rigs.$$ | head -1)
    fi
    rm -f /tmp/.gc-rig-join-rigs.$$
    if [ -n "$EXISTING_OWNER" ]; then
        die "prefix '$PREFIX' already registered in this city by rig $EXISTING_OWNER (use a different --prefix or remove the conflicting rig first)"
    fi
fi

# Pre-flight 2: target dolt server must have the database.
# Without this we'd fall through to ensure-project-id and surface a generic
# "Error 1049 (HY000): database not found" — confusing for first-time joiners.
if command -v dolt >/dev/null 2>&1; then
    DBS_OUT=$(DOLT_CLI_PASSWORD="$PASSWORD" \
              dolt --no-tls --user "$USER_" \
                   --host "$HOST" --port "$PORT" \
                   sql --query "SHOW DATABASES;" --result-format=csv 2>&1) || {
        die "cannot reach dolt server at $HOST:$PORT (user=$USER_): $(echo "$DBS_OUT" | head -1)"
    }
    # CSV: first line is header "Database", subsequent lines are db names.
    if ! echo "$DBS_OUT" | tail -n +2 | grep -qFx "$PREFIX"; then
        AVAILABLE=$(echo "$DBS_OUT" | tail -n +2 | grep -vE '^(information_schema|mysql|__.+)$' | tr '\n' ' ')
        die "database '$PREFIX' does not exist on $HOST:$PORT (city A must run 'gc rig add' first to create it; available: $AVAILABLE)"
    fi
    # Pre-flight 3: database must be bd-shaped before we adopt.
    # If the DB exists but is empty (someone created it manually for some other
    # purpose), `gc rig add --adopt` would happily wire us in and `bd list` would
    # then explode at first read. Catch it here.
    TBLS=$(DOLT_CLI_PASSWORD="$PASSWORD" \
           dolt --no-tls --user "$USER_" \
                --host "$HOST" --port "$PORT" \
                sql --query "USE \`$PREFIX\`; SHOW TABLES;" --result-format=csv 2>&1) || {
        die "cannot enumerate tables in database '$PREFIX' on $HOST:$PORT: $(echo "$TBLS" | head -1)"
    }
    for required in metadata issues schema_migrations; do
        if ! echo "$TBLS" | tail -n +2 | grep -qFx "$required"; then
            die "database '$PREFIX' on $HOST:$PORT is missing the '$required' table — not a bd-initialized database (city A must run 'bd init' / 'gc rig add' against it first)"
        fi
    done
else
    echo "warning: 'dolt' not on PATH; skipping server reachability + bd-shape pre-flight checks" >&2
fi

echo "==> Joining shared rig"
echo "    local-path:    $LOCAL"
echo "    prefix:        $PREFIX"
echo "    rig name:      $NAME"
echo "    shared dolt:   $HOST:$PORT (user=$USER_)"
echo "    pin endpoint:  $([ "$PIN_ENDPOINT" -eq 1 ] && echo yes || echo no)"
[ "$DRY_RUN" -eq 1 ] && echo "    dry-run:       yes"
echo

# Step 1: pre-stage .beads/  -----------------------------------------------
BEADS_DIR="$LOCAL/.beads"
CONFIG_YAML="$BEADS_DIR/config.yaml"
METADATA_JSON="$BEADS_DIR/metadata.json"

if [ -e "$CONFIG_YAML" ] || [ -e "$METADATA_JSON" ]; then
    echo "==> Step 1: .beads/ already present, leaving it alone"
    if [ -e "$CONFIG_YAML" ] && ! grep -q "^issue_prefix: *$PREFIX\$" "$CONFIG_YAML"; then
        die "$CONFIG_YAML has a different issue_prefix than --prefix=$PREFIX; remove .beads/ and re-run"
    fi
else
    echo "==> Step 1: pre-stage .beads/ stub"
    if [ "$DRY_RUN" -eq 1 ]; then
        echo "WOULD MKDIR: $BEADS_DIR"
    else
        mkdir -p "$BEADS_DIR"
    fi
    write_file "$CONFIG_YAML" "$(cat <<EOF
issue_prefix: $PREFIX
issue-prefix: $PREFIX
dolt.auto-start: false
EOF
)"
    write_file "$METADATA_JSON" "$(cat <<EOF
{
  "backend": "dolt",
  "database": "dolt",
  "dolt_database": "$PREFIX",
  "dolt_mode": "server"
}
EOF
)"
fi
echo

# Step 2: pull canonical project_id ----------------------------------------
echo "==> Step 2: gc dolt-state ensure-project-id"
run gc dolt-state ensure-project-id \
    --metadata "$METADATA_JSON" \
    --host "$HOST" --port "$PORT" --user "$USER_" \
    --database "$PREFIX"
echo

# Step 3: register the rig --------------------------------------------------
echo "==> Step 3: gc rig add --adopt"
run gc rig add "$LOCAL" --name "$NAME" --prefix "$PREFIX" --adopt
echo

# Step 4 (optional): pin per-rig endpoint ----------------------------------
if [ "$PIN_ENDPOINT" -eq 1 ]; then
    echo "==> Step 4: gc rig set-endpoint --external"
    run gc rig set-endpoint "$NAME" --external \
        --host "$HOST" --port "$PORT" --user "$USER_"
    echo
fi

echo "Done. Verify with:"
echo "  ( cd $LOCAL && bd list --limit 5 )"
echo "  gc rig list"
echo "  gc rig status $NAME"
